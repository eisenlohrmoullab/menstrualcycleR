.DS_Store
inst/doc
/Meta/

/doc/

# Repo = code only. Block session/scratch work-files at the repo root so they can
# never be committed (and so pkgdown can't render them onto the public site, as
# happened pre-0.1.3 with _READINESS_PLAN / _DRAFT_PR). Root-anchored so package
# code (R/, man/) and _pkgdown.yml are unaffected.
/_*.md
/_*.svg
/_*.R
/_*.json

# shinyapps.io deploy bookkeeping (auto-generated on deploy; app/bundle IDs only,
# no secrets). Should not be version-controlled or shipped in the package tarball.
/rsconnect/
inst/shiny/rsconnect/

# R CMD build / check artifacts
*.Rcheck/
..Rcheck/
*.tar.gz
